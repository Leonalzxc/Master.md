#!/usr/bin/env sh

cd "$(dirname -- "$0")/.."

echo "🔍 Running pre-commit checks..."

echo "→ typecheck"
npm run typecheck || exit 1

echo "→ format:check"
npm run format:check || {
  echo ""
  echo "❌ Formatting issues found. Run: npm run format --prefix web"
  exit 1
}

echo "→ lint"
npm run lint || exit 1

echo "✅ All pre-commit checks passed"